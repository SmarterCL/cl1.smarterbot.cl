# =============================================================================
# SmarterOS CL1 Node - Environment Variables Template
# =============================================================================
# COPIAR ESTE ARCHIVO A: env/.env
# COMPLETAR CON VALORES REALES DESDE SUPABASE VAULT
# =============================================================================

# -----------------------------------------------------------------------------
# Sistema
# -----------------------------------------------------------------------------
NODE_ENV=production
TZ=America/Santiago

# -----------------------------------------------------------------------------
# Supabase - Secrets Manager
# -----------------------------------------------------------------------------
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-key-aqui

# -----------------------------------------------------------------------------
# MCP Core - API Keys
# -----------------------------------------------------------------------------
MCP_API_KEY=tu-mcp-api-key-aqui
OPENAI_API_KEY=tu-openai-api-key-aqui
# Alternativas:
# ANTHROPIC_API_KEY=tu-anthropic-key-aqui
# MINIMAX_API_KEY=tu-minimax-key-aqui

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=tu-redis-password-aqui

# -----------------------------------------------------------------------------
# n8n - Automatización
# -----------------------------------------------------------------------------
N8N_ENCRYPTION_KEY=tu-n8n-encryption-key-aqui
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=tu-n8n-password-aqui

# -----------------------------------------------------------------------------
# CL1 Node - Configuración
# -----------------------------------------------------------------------------
PORT=3000
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Ollama (si se usa local en VPS)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=codellama:7b
# Modelos disponibles:
# llama2, codellama, mistral, neural-chat, etc.

# -----------------------------------------------------------------------------
# PicoClaw - Hardware biológico (Cortical Labs)
# -----------------------------------------------------------------------------
PICOCLAW_URL=http://localhost:3100
PICOCLAW_NODE=cl1.smarterbot.cl

# -----------------------------------------------------------------------------
# Integraciones externas
# -----------------------------------------------------------------------------
# Kaggle (para SmarterMCP)
KAGGLE_USERNAME=tu-kaggle-username
KAGGLE_API_KEY=tu-kaggle-api-key

# URLs de servicios
CL1_URL=https://cl1.smarterbot.cl
MCP_URL=https://mcp.smarterbot.cl
N8N_URL=https://n8n.smarterbot.cl
