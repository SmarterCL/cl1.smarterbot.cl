# =============================================================================
# Caddyfile - Reverse Proxy para SmarterOS
# =============================================================================
# SSL automático con Let's Encrypt
# Dominios configurados para cl1.smarterbot.cl
# =============================================================================

{
    email admin@smarterbot.cl
    # Solicitar certificados para todos los dominios
    # on_demand_tls {
    #     ask https://internal.smarterbot.cl/tls-check
    # }
}

# -----------------------------------------------------------------------------
# CL1 Node - Núcleo de procesamiento AI
# -----------------------------------------------------------------------------
cl1.smarterbot.cl {
    reverse_proxy cl1-node:3000
    
    # Headers de seguridad
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    
    # Log
    log {
        output file /var/log/caddy/cl1-access.log
    }
}

# -----------------------------------------------------------------------------
# MCP Core - Herramientas y kernel
# -----------------------------------------------------------------------------
mcp.smarterbot.cl {
    reverse_proxy mcp-core:8080
    
    # Headers para SSE/WebSocket
    header {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
    }
    
    log {
        output file /var/log/caddy/mcp-access.log
    }
}

# -----------------------------------------------------------------------------
# n8n - Automatización
# -----------------------------------------------------------------------------
n8n.smarterbot.cl {
    reverse_proxy n8n:5678
    
    # Headers de seguridad
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
    }
    
    log {
        output file /var/log/caddy/n8n-access.log
    }
}

# -----------------------------------------------------------------------------
# Ollama Local - Inference API
# -----------------------------------------------------------------------------
ollama.smarterbot.cl {
    reverse_proxy ollama:11434
    
    # Para clientes que consumen la API de Ollama
    header {
        Access-Control-Allow-Origin "*"
    }
    
    log {
        output file /var/log/caddy/ollama-access.log
    }
}

# -----------------------------------------------------------------------------
# Health checks internos
# -----------------------------------------------------------------------------
health.smarterbot.cl {
    reverse_proxy /health cl1-node:3000
    respond / "OK" 200
}
